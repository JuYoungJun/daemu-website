# DAEMU Website — Environment Variables
# Copy this file to `.env` (in the project root) and fill in your keys.
# After editing .env, run: npm run build && npm run preview

# ── Backend API base URL ─────────────────────────────────
# 실제 백엔드(Cloudflare Workers / Vercel / 카페24 등) 배포 후 그 URL을 입력.
# 비워두면 모든 발송은 시뮬레이션되어 /admin/outbox 에 기록됩니다.
# 예: https://daemu-api.your-subdomain.workers.dev
VITE_API_BASE_URL=

# ── Plausible Analytics (선택, 도메인 필요) ─────────────────
# Sign up: https://plausible.io 또는 self-host Umami (https://umami.is)
# 도메인 등록 전이면 비워두세요. 사이트는 정상 동작, 분석만 OFF.
VITE_PLAUSIBLE_DOMAIN=

# Self-host 사용 시 본인 인스턴스 URL. 기본은 plausible.io.
# VITE_PLAUSIBLE_API_HOST=https://plausible.io
