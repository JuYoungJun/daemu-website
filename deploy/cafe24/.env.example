# DAEMU 백엔드 운영 환경변수 — Cafe24 VPS.
#
# 위치: /srv/daemu/backend/.env
# 권한: chown daemu:daemu .env && chmod 600 .env  (must)
# 적용: systemctl restart daemu-backend
#
# ⚠ 이 파일을 그대로 .env 로 복사한 후 *반드시* 모든 placeholder 값을 교체하세요.
#   교체 안 한 값으로 그대로 띄우면 보안 사고가 납니다 (기본 비밀번호 등).
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ❗ FAIL-CLOSED 필수 4개 (없으면 backend 시작 거부, RuntimeError):
#     ENV=prod
#     JWT_SECRET           ← 64자 hex (openssl rand -hex 32)
#     DATABASE_URL         ← mysql+aiomysql://user:pass@host:3306/db
#     ADMIN_PASSWORD       ← 강한 비밀번호 (daemu1234 등 default 시 차단)
#
# 추가 강력 권장 (운영 정상 동작용):
#     SHORT_LINK_HMAC_SECRET, RESEND_API_KEY 또는 SMTP_HOST/USER/PASS,
#     ALLOWED_ORIGINS, PUBLIC_BASE_URL, TRUST_FORWARDED_FOR=1, MYSQL_SSL_CA
#
# 이 파일에 secret 값 자체를 적은 채 commit 하지 마세요 (.gitignore 됨).
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─────────────────────────────────────────────────────────────────
# 1) 환경 / 운영 모드
# ─────────────────────────────────────────────────────────────────
ENV=prod
LOG_LEVEL=INFO

# uvicorn 이 listen 할 포트. systemd unit 의 --port 와 일치시킬 것.
# 외부 노출 X (nginx 가 reverse-proxy). 변경 시 systemd unit 도 함께 변경.
PORT=8001

# ─────────────────────────────────────────────────────────────────
# 2) 도메인 / CORS / Public URL
# ─────────────────────────────────────────────────────────────────
# 프론트가 호스팅되는 도메인(들). 동일 도메인이면 한 개. 다중 도메인은 콤마.
ALLOWED_ORIGINS=https://example.daemu.kr,https://www.example.daemu.kr

# 사용자가 받는 short link / e-sign URL 의 base. 보통 ALLOWED_ORIGINS 와 같은 도메인.
PUBLIC_BASE_URL=https://example.daemu.kr

# Cloudflare / nginx X-Forwarded-For 신뢰 여부. nginx 뒤에서는 1 (true).
TRUST_FORWARDED_FOR=1

# ─────────────────────────────────────────────────────────────────
# 3) 데이터베이스 — Aiven MySQL 8 (그대로 유지)
# ─────────────────────────────────────────────────────────────────
# Aiven Service URI 그대로 붙여넣기. backend 가 자동으로 mysql+aiomysql:// 로 변환.
# ⚠ Cafe24 의 한국 IP 가 Aiven IP allowlist 에 등록돼 있어야 합니다.
#   Aiven Console → Service → Allowed IP addresses → Cafe24 VPS public IP 추가.
DATABASE_URL=mysql://avnadmin:PASSWORD@HOST:PORT/defaultdb

# Aiven 의 self-signed CA PEM 전체 — 브라우저로 console 열어 download → 그대로 붙여넣기.
# verify-required SSL 모드 활성화 (필수, 운영 보안).
MYSQL_SSL_CA="-----BEGIN CERTIFICATE-----
PASTE_AIVEN_CA_PEM_HERE
-----END CERTIFICATE-----"

# 드라이버. asyncmy(기본) 가 caching_sha2_password 핸드셰이크 깨지면 aiomysql 로.
MYSQL_DRIVER=aiomysql

# 같은 VPC 내 self-host MySQL 등 SSL 우회가 필요한 경우만 1.
# DAEMU_MYSQL_SSL_DISABLE=0

# ─────────────────────────────────────────────────────────────────
# 4) 인증 / JWT
# ─────────────────────────────────────────────────────────────────
# 토큰 서명 비밀키. 미설정 시 부팅마다 임의 생성 → 모든 세션이 재배포마다 invalid.
# 운영에서는 *반드시* 고정값 (32+ bytes hex). 발급:  openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32

# 토큰 유효기간 (시간). 기본 12. CSV 다운로드 등 어드민 작업 흐름 고려해 12~24 권장.
JWT_TTL_HOURS=12

# ─────────────────────────────────────────────────────────────────
# 5) 첫 부팅 시드 어드민 — 첫 deploy 후 즉시 비밀번호 변경하세요!
# ─────────────────────────────────────────────────────────────────
# 첫 부팅에만 의미가 있음. 기존 사용자는 절대 덮어쓰지 않음.
ADMIN_EMAIL=admin@example.daemu.kr
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
TESTER_EMAIL=tester@example.daemu.kr
TESTER_PASSWORD=CHANGE_ME_TESTER_PASSWORD
DEVELOPER_EMAIL=dev@example.daemu.kr
DEVELOPER_PASSWORD=CHANGE_ME_DEV_PASSWORD

# ENV=prod 이면 TEST_ADMIN_EMAIL/PASSWORD 가 set 돼 있으면 부팅이 fail-closed.
# (우회 계정은 운영에서 절대 금지)
# TEST_ADMIN_EMAIL=
# TEST_ADMIN_PASSWORD=

# ⚠ 임시 emergency 2FA reset — 사용 후 *반드시* 즉시 삭제.
#   이 값이 set 된 동안엔 부팅마다 해당 계정의 2FA 가 풀립니다.
# DAEMU_RESET_TOTP_EMAIL=

# ─────────────────────────────────────────────────────────────────
# 6) 이메일 발송 — Resend (권장) 또는 SMTP
# ─────────────────────────────────────────────────────────────────
# 두 방식 중 하나만 채우세요. 둘 다 비면 발송이 simulated (실제 발송 X).
# Resend: re_xxx... API 키. https://resend.com → API Keys.
RESEND_API_KEY=

# 발송 표기 — RFC 5322 display-name 형식. "DAEMU 베이커리·카페 컨설팅"
# 부분이 메일 클라이언트의 발신자 칸에 prominent 하게 표시되고 실제 메일
# 주소는 그 뒤에 작게 노출. 도메인 verify 후 noreply@example.daemu.kr.
FROM_EMAIL=DAEMU 베이커리·카페 컨설팅 <onboarding@resend.dev>

# SMTP 대안 — Resend 안 쓸 때만 사용. RESEND_API_KEY 가 있으면 Resend 가 우선.
# Gmail 임시 (앱 비밀번호 16자 발급 — google.com/security/apppasswords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=ops@daemu.kr
#   SMTP_PASS=<앱 비번 — 24~48h 회전 권장>
#   SMTP_FROM=DAEMU 베이커리·카페 컨설팅 <ops@daemu.kr>
#   SMTP_USE_TLS=1
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_USE_TLS=1

# ─────────────────────────────────────────────────────────────────
# 7) 단축링크 (UTM 캠페인)
# ─────────────────────────────────────────────────────────────────
# HMAC 서명용 — 미설정 시 SHA256 fallback 으로 약함. 발급: openssl rand -hex 32
SHORT_LINK_HMAC_SECRET=REPLACE_WITH_openssl_rand_-hex_32

# 사용자가 보는 short URL prefix. 도메인 확정 후 변경.
SHORT_LINK_BASE=https://example.daemu.kr/r/

# 기본 만료 일수 (없으면 365). 0 이면 무기한.
SHORT_LINK_DEFAULT_TTL_DAYS=365

# ─────────────────────────────────────────────────────────────────
# 8) 데이터 보존 (PIPA / 전자상거래법)
# ─────────────────────────────────────────────────────────────────
# Contact 폼 / Inquiries 보존일 (전자상거래법 기본 3년).
INQUIRY_RETENTION_DAYS=1095
# 발송 outbox 보존일.
OUTBOX_RETENTION_DAYS=365
# 의심 이벤트 보존일 — login throttle lock 도달 시 brute_force_login 자동
# 기록. evidence=true 봉인된 row 만 365일, 그 외 90일 권장. cron auto sweep.
SUSPICIOUS_RETENTION_DAYS=90
SUSPICIOUS_EVIDENCE_RETENTION_DAYS=365

# ─────────────────────────────────────────────────────────────────
# 9) 부가 기능
# ─────────────────────────────────────────────────────────────────
# GeoIP 조회 (관리자 페이지 IP-위치 표시). ipapi.co free tier 충분.
GEO_API_URL=https://ipapi.co/{ip}/json/

# 2FA 분실 복구는 host-agnostic 경로 사용 (env 의존 X):
#   1) 로그인 화면 "2단계 인증 분실?" → 이메일 입력 → 5분 TTL 복구 링크.
#      backend POST /api/auth/totp-reset-request → 메일 발송.
#      필요: PUBLIC_BASE_URL 설정 (메일 본문의 링크 생성용).
#   2) 메일 / 링크 / 백업코드 모두 잃은 비상시 — host shell 에서 CLI 실행:
#        cd /srv/daemu/backend
#        .venv/bin/python -m manage reset-2fa --email <email>
#      (audit_logs 에 actor='cli' 로 기록 됨)
#   3) 또 다른 admin role 계정이 있으면 /admin/users 의 "2FA 강제 해제" 버튼.

# ─────────────────────────────────────────────────────────────────
# 10) 운영 베스트 프랙티스 — 실제 변경 X, 가이드 only
# ─────────────────────────────────────────────────────────────────
# - 이 파일을 git 에 커밋하지 마세요. .gitignore 에 deploy/cafe24/.env 추가.
# - .env 권한: chmod 600. systemd User=daemu 만 read.
# - 변경 후: sudo systemctl restart daemu-backend
# - 검증: curl -fsS https://example.daemu.kr/api/health | jq .databaseConnected
