# DAEMU production .env — Cafe24 VPS 최소 필수 8개.
#
# 본 파일은 *junior 개발자가 따라하기 쉬운 minimal* 버전입니다.
# 전체 27개 env 가이드는 .env.example (옆 파일) 참조.
#
# 사용 절차:
#   1) cp .env.production.minimal.example /srv/daemu/backend/.env
#   2) 모든 < ... > placeholder 를 실제 값으로 교체
#   3) chown daemu:daemu /srv/daemu/backend/.env
#   4) chmod 600 /srv/daemu/backend/.env       (누구도 읽지 못하게)
#   5) sudo systemctl restart daemu-backend
#   6) 검증: curl -fsS https://<도메인>/api/health  → {"ok": true}
#
# ⚠ 이 파일을 git 에 commit 하지 마세요 (.gitignore 가 차단합니다).
# ⚠ Slack / 이메일 / 채팅으로 secret 공유 금지. password manager 사용.

# ── FAIL-CLOSED 필수 4개 ──────────────────────────────────────────
# 누락 시 backend 가 RuntimeError 로 즉시 시작 거부.
# 약한 default 비밀번호 (daemu1234 / tester1234 / dev1234 등) 도 거부.

ENV=prod

# 새로 생성: openssl rand -hex 32
JWT_SECRET=<64자_hex_새로_생성>

# Cafe24 self-host MariaDB 또는 managed MySQL (Aiven/PlanetScale/RDS).
# aiomysql 가 default driver — caching_sha2_password 호환성.
# Aiven 인 경우 ?ssl=true 추가 + MYSQL_SSL_CA env 도 같이 set.
DATABASE_URL=mysql+aiomysql://daemu_user:<강한_DB_비밀번호>@127.0.0.1:3306/daemu_db

# 슈퍼관리자 첫 로그인용. 첫 로그인 직후 어드민 화면에서 즉시 변경.
# 약한 default 거부됨 (auth.py 의 _weak_defaults set 참조).
ADMIN_PASSWORD=<강한_운영_비밀번호>

# ── 운영 정상 동작 권장 ────────────────────────────────────────────

# 단축 링크 위변조 방지 — 운영 시 강력 권장.
SHORT_LINK_HMAC_SECRET=<64자_hex_새로_생성>

# 운영 도메인 — CORS allowlist + 메일 링크 / public base URL 에 사용.
ALLOWED_ORIGINS=https://example.com,https://www.example.com
PUBLIC_BASE_URL=https://example.com

# nginx 가 reverse-proxy 면 1, backend 가 직접 외부 노출이면 0.
TRUST_FORWARDED_FOR=1

# 메일 발송 — 둘 중 하나만.
# (a) Resend (도메인 verified 후 권장):
RESEND_API_KEY=<re_xxx_resend_api_key>
FROM_EMAIL=DAEMU 베이커리·카페 컨설팅 <noreply@example.com>

# (b) 또는 SMTP (Gmail 앱 비밀번호 / 회사 SMTP 등):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=<발신_이메일>
# SMTP_PASS=<앱_비밀번호_16자>
# SMTP_FROM=DAEMU 베이커리·카페 컨설팅 <발신_이메일>
# SMTP_USE_TLS=1

# Aiven / managed MySQL 의 self-signed CA 사용 시.
# Cafe24 self-host MariaDB 면 보통 불필요.
# MYSQL_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
