# DAEMU Website — Environment Variables
# Copy this file to `.env` (in the project root) and fill in your keys.
# After editing .env, run: npm run build && npm run preview
#
# Production build (GitHub Actions) reads from repo Variables/Secrets.
# Use the same key names there.

# ── Backend API base URL ─────────────────────────────────
# 실제 백엔드 배포 후 그 URL을 입력.
# 비워두면 모든 발송은 시뮬레이션되어 /admin/outbox 에 기록됩니다.
# 예: https://daemu-py.onrender.com
VITE_API_BASE_URL=

# ── Site canonical URL ───────────────────────────────────
# 빌드 시점에 React 페이지의 canonical / og:url / JSON-LD URL 에 사용됩니다.
# GitHub Pages 단계에서는 비워두세요 (기본값 https://juyoungjun.github.io/daemu-website 사용).
# 실제 도메인 발급 후 예: https://daemu.kr
VITE_SITE_BASE_URL=

# ── Plausible Analytics (선택, 도메인 필요) ─────────────────
# https://plausible.io 가입 후 등록한 도메인.
# 비워두면 Plausible 스크립트가 로드되지 않고 사이트 분석만 OFF됩니다.
VITE_PLAUSIBLE_DOMAIN=

# Self-host 사용 시 본인 인스턴스 URL. 기본은 plausible.io.
# VITE_PLAUSIBLE_API_HOST=https://plausible.io

# ── Google Analytics 4 (선택) ───────────────────────────
# https://analytics.google.com 새 속성 → 측정 ID(G-XXXXXXXXXX).
# 비워두면 GA4 스크립트는 절대 로드되지 않고 동의 배너도 안 뜹니다.
# 설정된 경우에만 사용자 동의 후 익명/IP 마스킹 모드로 GA4가 활성화됩니다.
VITE_GA4_ID=
