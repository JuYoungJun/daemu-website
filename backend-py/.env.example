# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=DAEMU <onboarding@resend.dev>

# Database — default SQLite (file-based) for dev only.
# For production (Cafe24 / Aiven / managed MySQL):
#   DATABASE_URL=mysql+aiomysql://user:pass@host:3306/daemu
# (aiomysql 가 default driver — caching_sha2_password 호환성. asyncmy 도 가능
#  하면 MYSQL_DRIVER=asyncmy 환경변수로 swap.)
DATABASE_URL=sqlite+aiosqlite:///./daemu.db

# Auth — JWT secret + first-boot admin seed
JWT_SECRET=
ADMIN_EMAIL=admin@daemu.kr
ADMIN_PASSWORD=daemu1234
JWT_TTL_HOURS=12

# CORS
ALLOWED_ORIGINS=http://localhost:8765,http://localhost:5173,http://localhost:8766,https://juyoungjun.github.io

# Optional: forces upload URLs to use this base instead of detecting from request host
PUBLIC_BASE_URL=

PORT=3000
