# Local backend environment
# Copy to backend/.env and fill in.

# Resend API key — get from https://resend.com/api-keys
# Stays on the server, NEVER expose to the browser.
RESEND_API_KEY=

# Sender. Without verified domain, Resend allows only:
#   onboarding@resend.dev — but only to your own account email.
# After domain verification, use noreply@your-domain.com
FROM_EMAIL=DAEMU <onboarding@resend.dev>

# CORS — comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:8765,http://localhost:5173,http://127.0.0.1:8765

# Listen port
PORT=3000
