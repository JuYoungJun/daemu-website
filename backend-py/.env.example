# Required for actual email sending
RESEND_API_KEY=

# Display name + sender (must be a Resend-verified address; sandbox uses onboarding@resend.dev)
FROM_EMAIL=DAEMU <onboarding@resend.dev>

# Comma-separated origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:8765,http://localhost:5173,https://juyoungjun.github.io

# Optional: forces upload URLs to use this base instead of detecting from request host
PUBLIC_BASE_URL=

PORT=3000
